Options -Indexes
ServerSignature Off
DirectoryIndex index.html

# ---- URL REWRITING ----------------------------------------
RewriteEngine On

# Frontend pages now live as static HTML
RewriteRule ^index\.php$ /index.html [L,R=302]
RewriteRule ^marketplace\.php$ /marketplace.html [L,R=302]
RewriteRule ^products\.php$ /products.html [L,R=302]
RewriteRule ^dog\.php$ /dog.html [L,R=302]
RewriteRule ^services\.php$ /services.html [L,R=302]
RewriteRule ^login\.php$ /login.html [L,R=302]
RewriteRule ^register\.php$ /register.html [L,R=302]
RewriteRule ^seller-verification\.php$ /seller-verification.html [L,R=302]
RewriteRule ^dashboard\.php$ /dashboard.html [L,R=302]
RewriteRule ^admin/index\.php$ /admin/index.html [L,R=302]

# Remove trailing slash (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Block access to PHP includes and config
RewriteRule ^(php|includes)/.*$ /404.html [L,F]

# ---- SECURITY HEADERS -------------------------------------
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'"
</IfModule>

# ---- BLOCK SENSITIVE FILES ---------------------------------
<FilesMatch "\.(sql|log|env|htpasswd|htaccess|git|sh|bak|swp)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ---- PROTECT UPLOADS DIRECTORY ----------------------------
<Directory "uploads/ids">
  <FilesMatch "\.php$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</Directory>

# ---- GZIP COMPRESSION -------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ---- BROWSER CACHING --------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ---- PREVENT SCRIPT INJECTION IN UPLOADS ------------------
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phar)$">
  <If "%{REQUEST_URI} =~ m#^/uploads/#">
    Order allow,deny
    Deny from all
  </If>
</FilesMatch>

# ---- ERROR PAGES ------------------------------------------
ErrorDocument 404 /404.html
ErrorDocument 403 /403.html
ErrorDocument 500 /500.html
